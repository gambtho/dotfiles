{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(just:*)",
      "Bash(bundle:*)",
      "Bash(bin/rails:*)",
      "Bash(rails:*)",
      "Bash(ruby:*)",
      "Bash(node:*)",
      "Bash(node_modules/.bin/:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(python3:*)",
      "Bash(pip install:*)",
      "Bash(bash:*)",
      "Bash(psql:*)",
      "Bash(pg_isready:*)",
      "Bash(redis-cli:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(jq:*)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(base64:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(convert:*)",
      "Bash(identify:*)",
      "Bash(mise:*)",
      "Bash(coderabbit:*)",
      "Bash(claude:*)",
      "Read(//workspaces/**)",
      "Read(//tmp/**)",
      "Read(~/.claude/**)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:developer.ebay.com)",
      "WebFetch(domain:www.ebay.com)",
      "WebFetch(domain:pages.ebay.com)",
      "WebFetch(domain:community.ebay.com)",
      "WebFetch(domain:developers.facebook.com)",
      "WebFetch(domain:render.com)",
      "WebFetch(domain:api-docs.render.com)",
      "WebFetch(domain:www.tcgplayer.com)",
      "WebFetch(domain:infinite-api.tcgplayer.com)",
      "WebFetch(domain:bulbapedia.bulbagarden.net)",
      "WebFetch(domain:api.psacard.com)",
      "mcp__supabase",
      "mcp__render",
      "mcp__storybook-mcp",
      "mcp__plugin_playwright_playwright",
      "mcp__plugin_linear_linear"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/ai/claude/hooks/worktree-guard.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "microsoft-docs@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "ai-firstify@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "my@guarzo": true,
    "linear@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "ai-firstify@techwolf-ai-first": false,
    "shopify@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto",
  "skipAutoPermissionPrompt": true,
  "compactSystemPrompt": "When summarizing this conversation, preserve the following in priority order:\n\n1. ACTIVE TASK STATE: What the user was working on, which files were modified, what was completed and what remains. Include specific file paths and function names.\n\n2. DECISIONS AND REASONING: Any choices made during the session, including why alternatives were rejected. If the user corrected my approach, record both the correction and the reason.\n\n3. BEHAVIORAL CONSTRAINTS (from the user's CLAUDE.md): Scope discipline (minimum change, propose expansions before doing them), verify before acting (run git/gh before amending, cite evidence before claiming completion), stop and ask instead of guessing, run things myself via Bash rather than asking the user to run them.\n\nThe summary should be dense and specific — err toward preserving too much detail rather than too little. Avoid vague statements like 'the user was working on the codebase.' Name the actual files, decisions, and constraints."
}
