#!/usr/bin/env bash

set -e

source "$(dirname "${BASH_SOURCE[0]}")/common.sh"

cd "$(dirname "${BASH_SOURCE[0]}")/.."
DOTFILES_ROOT=$(pwd -P)

BOOTSTRAP_PROFILE=""
NON_INTERACTIVE=false
BOOTSTRAP_GIT_NAME=""
BOOTSTRAP_GIT_EMAIL=""

# sudo -v  # disabled: prompts on passwordless accounts; NOPASSWD sudoers covers later calls

parse_bootstrap_args() {
  while (($# > 0)); do
    case "$1" in
      --allow-remote-installers)
        export ALLOW_REMOTE_INSTALLERS=1
        ;;
      --profile)
        if (($# < 2)); then
          printf '%s\n' "--profile requires personal, work, or server." >&2
          return 2
        fi
        case "$2" in
          personal | work | server)
            BOOTSTRAP_PROFILE="$2"
            ;;
          *)
            printf 'Unsupported profile: %s\n' "$2" >&2
            return 2
            ;;
        esac
        shift
        ;;
      --non-interactive)
        NON_INTERACTIVE=true
        ;;
      *)
        printf 'Unknown bootstrap option: %s\n' "$1" >&2
        return 2
        ;;
    esac
    shift
  done
}

validate_bootstrap_options() {
  if [[ "$NON_INTERACTIVE" != true ]]; then
    return 0
  fi
  if [[ -z "$BOOTSTRAP_PROFILE" ]]; then
    printf '%s\n' "--profile is required with --non-interactive." >&2
    return 1
  fi
  if [[ -f "$DOTFILES_ROOT/core/git/gitconfig.local.symlink" ]]; then
    return 0
  fi
  BOOTSTRAP_GIT_NAME=$(git config --global --get user.name 2>/dev/null || true)
  BOOTSTRAP_GIT_EMAIL=$(git config --global --get user.email 2>/dev/null || true)
  if [[ -z "$BOOTSTRAP_GIT_NAME" || -z "$BOOTSTRAP_GIT_EMAIL" ]]; then
    printf '%s\n' "Git user.name and user.email are required before non-interactive bootstrap." >&2
    return 1
  fi
}

setup_gitconfig() {
  if ! [ -f "$DOTFILES_ROOT/core/git/gitconfig.local.symlink" ]; then
    log_info "Setting up gitconfig"
    local git_authorname
    local git_authoremail
    if [[ "$NON_INTERACTIVE" == true ]]; then
      git_authorname="$BOOTSTRAP_GIT_NAME"
      git_authoremail="$BOOTSTRAP_GIT_EMAIL"
    else
      log_info " - What is your GitHub author name?"
      read -r -e git_authorname
      log_info " - What is your GitHub author email?"
      read -r -e git_authoremail
    fi

    sed -e "s|AUTHORNAME|$git_authorname|g" \
      -e "s|AUTHOREMAIL|$git_authoremail|g" \
      "$DOTFILES_ROOT/core/git/gitconfig.local.symlink.example" >"$DOTFILES_ROOT/core/git/gitconfig.local.symlink"

    log_success "Gitconfig setup completed"
  else
    log_info "Gitconfig already set up"
  fi
}

setup_profile() {
  if [[ -n "$BOOTSTRAP_PROFILE" ]]; then
    printf '%s\n' "$BOOTSTRAP_PROFILE" >"$HOME/.dotfiles-profile"
    log_success "Profile set to: $BOOTSTRAP_PROFILE"
    return
  fi

  if [ -f "$HOME/.dotfiles-profile" ]; then
    log_info "Profile already set to: $(cat "$HOME/.dotfiles-profile")"
    return
  fi

  log_info "Select a profile:"
  log_info "  1) personal"
  log_info "  2) work"
  log_info "  3) server  (headless/VPS, no GUI)"
  read -r -e -p "Enter choice [1/2/3]: " profile_choice

  case "$profile_choice" in
    1 | personal)
      echo "personal" >"$HOME/.dotfiles-profile"
      log_success "Profile set to: personal"
      ;;
    2 | work)
      echo "work" >"$HOME/.dotfiles-profile"
      log_success "Profile set to: work"
      ;;
    3 | server)
      echo "server" >"$HOME/.dotfiles-profile"
      log_success "Profile set to: server"
      ;;
    *)
      echo "personal" >"$HOME/.dotfiles-profile"
      log_warning "Unknown choice, defaulting to: personal"
      ;;
  esac
}

link_file() {
  local src=$1 dst=$2

  local overwrite='' backup='' skip=''
  local action=

  if [ -f "$dst" ] || [ -d "$dst" ] || [ -L "$dst" ]; then
    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]; then
      local currentSrc=""
      if [ -L "$dst" ]; then
        currentSrc=$(readlink "$dst")
      fi

      if [ "$currentSrc" == "$src" ]; then
        skip=true
      else
        log_warning "File already exists: $dst ($(basename "$src")), what do you want to do?
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -n 1 action </dev/tty
        echo

        case "$action" in
          o) overwrite=true ;;
          O) overwrite_all=true ;;
          b) backup=true ;;
          B) backup_all=true ;;
          s) skip=true ;;
          S) skip_all=true ;;
          *) ;;
        esac
      fi
    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]; then
      rm -rf "$dst"
      log_success "Removed $dst"
    fi

    if [ "$backup" == "true" ]; then
      mv "$dst" "${dst}.backup"
      log_success "Moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]; then
      log_info "Skipped $src"
      return
    fi
  fi

  ln -s "$src" "$dst"
  log_success "Linked $src to $dst"
}

install_dotfiles() {
  log_info "Installing dotfiles symlinks"

  mkdir -p "$DOTFILES_ROOT/tmp"
  touch "$DOTFILES_ROOT/tmp/brewfile"

  local overwrite_all=false backup_all=false skip_all="$NON_INTERACTIVE"

  # Link *.symlink files to $HOME/.<name>
  while IFS= read -r -d '' src; do
    dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done < <(find -H "$DOTFILES_ROOT" \
    -not -path '*/archived/*' \
    -not -path '*/.git/*' \
    -not -path '*/.claude/worktrees/*' \
    -name '*.symlink' -print0)

  # Link config/ subdirectories to ~/.config/<name>
  if [ -d "$DOTFILES_ROOT/config" ]; then
    mkdir -p "$HOME/.config"
    for config_dir in "$DOTFILES_ROOT/config"/*/; do
      config_name=$(basename "$config_dir")
      link_file "$config_dir" "$HOME/.config/$config_name"
    done
  fi

  log_success "Symlinks installed"
}

linux_prep() {
  log_info "Preparing Linux environment"

  sudo apt update
  sudo apt-get install -y ca-certificates curl gnupg build-essential \
    libssl-dev libreadline-dev zlib1g-dev libyaml-dev

  sudo install -m 0755 -d /etc/apt/keyrings

  if ! command_exists zsh; then
    log_info "Installing zsh"
    sudo apt install -y zsh
    log_success "zsh installed"
  else
    log_info "zsh already installed"
  fi

  if ! command_exists mise; then
    install_mise_ubuntu
  else
    log_info "mise already installed"
  fi
}

mac_prep() {
  log_info "Preparing macOS environment"

  if ! command_exists brew; then
    log_info "Installing Homebrew"
    run_remote_installer https://raw.githubusercontent.com/Homebrew/install/master/install.sh /bin/bash
    log_success "Homebrew installed"
  else
    log_info "Homebrew already installed"
  fi

  if ! command_exists zsh; then
    log_info "Installing zsh"
    brew install zsh
    log_success "zsh installed"
  else
    log_info "zsh already installed"
  fi

  if ! command_exists mise; then
    log_info "Installing mise"
    brew install mise
    log_success "mise installed"
  else
    log_info "mise already installed"
  fi
}

main() {
  parse_bootstrap_args "$@"
  validate_bootstrap_options
  detect_os

  case "$OS" in
    macOS)
      mac_prep
      ;;
    Ubuntu | WSL)
      linux_prep
      ;;
    *)
      log_warning "Unsupported operating system: $OS"
      exit 1
      ;;
  esac

  setup_gitconfig
  setup_profile
  install_dotfiles

  log_success "Bootstrap complete. Run 'bin/install' to complete setup."
}

if [[ "${BOOTSTRAP_SOURCE_ONLY:-0}" != 1 ]]; then
  main "$@"
fi
