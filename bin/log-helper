#!/usr/bin/env bash

DEBUG=${DEBUG:-false}


# Add timestamps to logs
timestamp() {
  date +"%Y-%m-%d %H:%M:%S"
}

# Log an info message
log_info() {
  printf "\r  [ \033[00;34mINFO\033[0m ] %s\n" "$1"
}

# Log a success message
log_success() {
  printf "\r  [ \033[00;32mSUCCESS\033[0m ] %s\n" "$1"
}

# Log a warning message
log_warning() {
  printf "\r  [ \033[0;33mWARNING\033[0m ] %s\n" "$1"
}

# Log an error message and exit
log_error() {
  printf "\r  [ \033[0;31mERROR\033[0m ] %s\n" "$1"
  exit 1
}

# Log a debug message (controlled by DEBUG environment variable)
log_debug() {
  if [[ "$DEBUG" == "true" ]]; then
    printf "\r  [ \033[00;35mDEBUG\033[0m ] %s\n" "$1"
  fi
}