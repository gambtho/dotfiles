#!/usr/bin/env bash
# Validate AI config structure for the 'my' Claude plugin: commands + skills.
# Usage: bin/validate-ai [--verbose]

set -e

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
PLUGIN_DIR="$DOTFILES_ROOT/ai/marketplace/plugins/my"
ERRORS=0
WARNINGS=0
VERBOSE=false

[[ "${1:-}" == "--verbose" ]] && VERBOSE=true

error() { echo "  ERROR: $1"; ((ERRORS++)); }
warn()  { echo "  WARN:  $1"; ((WARNINGS++)); }
info()  { $VERBOSE && echo "  OK:    $1" || true; }

echo "=== Validating 'my' plugin config ==="

# ── Commands ──────────────────────────────────────────────────────────────────
echo ""
echo "Commands:"
for cmd in "$PLUGIN_DIR"/commands/*.md; do
    [ -f "$cmd" ] || continue
    name=$(basename "$cmd")

    if ! head -1 "$cmd" | grep -q '^---$'; then
        error "$name: missing frontmatter"
        continue
    fi
    if ! grep -q '^description:' "$cmd"; then
        error "$name: missing 'description' in frontmatter"
    fi
    info "$name"
done

# ── Skills ────────────────────────────────────────────────────────────────────
echo ""
echo "Skills:"
for skill_dir in "$PLUGIN_DIR"/skills/*/; do
    [ -d "$skill_dir" ] || continue
    skill_name=$(basename "$skill_dir")

    if [ ! -f "$skill_dir/SKILL.md" ]; then
        error "$skill_name: missing SKILL.md"
        continue
    fi
    if ! head -1 "$skill_dir/SKILL.md" | grep -q '^---$'; then
        error "$skill_name/SKILL.md: missing frontmatter"
    fi
    if ! grep -q '^name:' "$skill_dir/SKILL.md"; then
        error "$skill_name/SKILL.md: missing 'name' in frontmatter"
    fi
    if ! grep -q '^description:' "$skill_dir/SKILL.md"; then
        error "$skill_name/SKILL.md: missing 'description' in frontmatter"
    fi
    info "$skill_name"
done

# ── Plugin manifest ───────────────────────────────────────────────────────────
echo ""
echo "Manifest:"
if [ ! -f "$PLUGIN_DIR/.claude-plugin/plugin.json" ]; then
    error "plugin.json: missing"
elif command -v jq &>/dev/null && ! jq empty "$PLUGIN_DIR/.claude-plugin/plugin.json" 2>/dev/null; then
    error "plugin.json: invalid JSON"
else
    info "plugin.json: valid JSON"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "=== Summary ==="
cmd_count=$(ls "$PLUGIN_DIR"/commands/*.md 2>/dev/null | wc -l)
skill_count=$(ls -d "$PLUGIN_DIR"/skills/*/ 2>/dev/null | wc -l)
echo "  Commands: $cmd_count"
echo "  Skills:   $skill_count"
echo "  Errors:   $ERRORS"
echo "  Warnings: $WARNINGS"

if [ $ERRORS -gt 0 ]; then
    echo ""
    echo "FAILED: $ERRORS errors found"
    exit 1
else
    echo ""
    echo "PASSED"
    exit 0
fi
