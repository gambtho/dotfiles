#!/usr/bin/env bash
# bin/claude-link-project — symlink personal claude overlays into a project tree.
#
# Looks up an overlay at ~/.dotfiles/projects/<basename(project-dir)>/
# and symlinks CLAUDE.md and .claude/ into the project. The global gitignore
# excludes those paths, so the project repo stays clean.
#
# Usage:
#   claude-link-project <project-dir>          # link
#   claude-link-project --unlink <project-dir> # remove symlinks (overlay stays)
#   claude-link-project --create <project-dir> # scaffold overlay then link
#   claude-link-project --local-md <project-dir>        # write CLAUDE.local.md import shim (project tracks its own CLAUDE.md)
#   claude-link-project --local-md --agents-md <dir>    # also write AGENTS.local.md import shim
#   claude-link-project --no-claude-md <project-dir>    # skip CLAUDE.md symlink entirely
#   claude-link-project --claude-dir-per-file <project-dir>
#       Symlink overlay's .claude/ contents file-by-file into project's .claude/
#       instead of symlinking the whole directory. Use when project tracks
#       .claude/ content. settings.local.json gets merged via jq.
#
# Example:
#   mkdir -p ~/.dotfiles/projects/slabledger/.claude
#   echo "# slabledger notes" > ~/.dotfiles/projects/slabledger/CLAUDE.md
#   claude-link-project ~/workspace/slabledger

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/.dotfiles}"
OVERLAY_ROOT="$DOTFILES/projects"

MODE="link"
PROJECT_DIR=""
SKIP_CLAUDE_MD=0
MODE_LOCAL_MD=0
SKIP_AGENTS_MD=1 # default: skip AGENTS.local.md (opt-in)
MODE_CLAUDE_PER_FILE=0

usage() {
  sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -u | --unlink)
      MODE="unlink"
      shift
      ;;
    -c | --create)
      MODE="create"
      shift
      ;;
    --no-claude-md)
      SKIP_CLAUDE_MD=1
      shift
      ;;
    --local-md)
      MODE_LOCAL_MD=1
      shift
      ;;
    --agents-md)
      SKIP_AGENTS_MD=0
      shift
      ;;
    --claude-dir-per-file)
      MODE_CLAUDE_PER_FILE=1
      shift
      ;;
    -h | --help) usage 0 ;;
    -*)
      echo "unknown flag: $1" >&2
      usage 1
      ;;
    *)
      PROJECT_DIR="$1"
      shift
      ;;
  esac
done

[[ -n "$PROJECT_DIR" ]] || {
  echo "missing project dir" >&2
  usage 1
}
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd -P)" || {
  echo "no such dir: $PROJECT_DIR" >&2
  exit 1
}
NAME="$(basename "$PROJECT_DIR")"
OVERLAY="$OVERLAY_ROOT/$NAME"

if [[ -t 1 ]]; then
  C_INFO=$'\033[36m'
  C_OK=$'\033[32m'
  C_WARN=$'\033[33m'
  C_ERR=$'\033[31m'
  C_OFF=$'\033[0m'
else
  C_INFO=""
  C_OK=""
  C_WARN=""
  C_ERR=""
  C_OFF=""
fi
info() { printf '%s%s%s\n' "$C_INFO" "$*" "$C_OFF"; }
ok() { printf '%s%s%s\n' "$C_OK" "$*" "$C_OFF"; }
warn() { printf '%s%s%s\n' "$C_WARN" "$*" "$C_OFF" >&2; }
die() {
  printf '%s%s%s\n' "$C_ERR" "$*" "$C_OFF" >&2
  exit 1
}

# ── unlink ───────────────────────────────────────────────────────────────────
unlink_one() {
  local target="$1"
  if [[ -L "$target" ]]; then
    rm "$target"
    ok "removed symlink: $target"
  elif [[ -e "$target" ]]; then
    warn "skipping $target — not a symlink (real file). Leave it as-is."
  fi
}

# Remove a .local.md import shim ONLY if its content is exactly the
# 1-line @~/ import this script would have written. Anything else (user
# additions, hand-edited content) is left in place.
unlink_local_md_shim() {
  local dst="$1"
  [[ -e "$dst" && ! -L "$dst" ]] || return 0 # nothing to do
  local first_line
  first_line="$(head -n1 "$dst" 2>/dev/null || true)"
  local line_count
  line_count="$(wc -l <"$dst" 2>/dev/null || echo 0)"
  # Expected shim: single line "@~/.dotfiles/projects/<slug>/..." (with a
  # trailing newline, so wc -l reports 1).
  if [[ "$line_count" == "1" && "$first_line" =~ ^@~?/.dotfiles/projects/ ]]; then
    rm "$dst"
    ok "removed import shim: $dst"
  else
    warn "skipping $dst — not a generated import shim (has $line_count lines or different content). Leave it as-is."
  fi
}

# Walk <project>/.claude/ and remove any symlinks pointing into our
# overlay. Skips real files (project's own). Removes now-empty
# directories on the way back up so we don't leave bare empty trees.
unlink_claude_dir_per_file() {
  local project_dir="$1" # <project>/.claude
  [[ -d "$project_dir" ]] || return 0

  # Phase 1: remove every symlink whose target sits under our OVERLAY.
  while IFS= read -r -d '' link; do
    local target
    target="$(readlink "$link")"
    if [[ "$target" == "$OVERLAY/.claude/"* || "$target" == "$OVERLAY/.claude" ]]; then
      rm "$link"
      ok "removed symlink: $link"
    fi
  done < <(find "$project_dir" -type l -print0)

  # Phase 2: prune now-empty dirs (rmdir, no -p, so it fails silently on
  # non-empty ones; -depth makes us process children first).
  find "$project_dir" -depth -type d -empty -not -path "$project_dir" -exec rmdir {} \; 2>/dev/null || true
}

if [[ "$MODE" == "unlink" ]]; then
  unlink_one "$PROJECT_DIR/CLAUDE.md"
  unlink_local_md_shim "$PROJECT_DIR/CLAUDE.local.md"
  unlink_local_md_shim "$PROJECT_DIR/AGENTS.local.md"
  # If .claude/ is itself a symlink to our overlay (legacy mode), remove it.
  # Otherwise treat it as per-file mode and walk for our symlinks.
  if [[ -L "$PROJECT_DIR/.claude" ]]; then
    unlink_one "$PROJECT_DIR/.claude"
  else
    unlink_claude_dir_per_file "$PROJECT_DIR/.claude"
  fi
  ok "Unlinked overlay from $PROJECT_DIR (overlay still at $OVERLAY)."
  exit 0
fi

# ── create scaffold ──────────────────────────────────────────────────────────
if [[ "$MODE" == "create" ]]; then
  # Refuse to scaffold/link a personal CLAUDE.md if the project already has
  # one (unless --no-claude-md skips that part). The symlink would clobber.
  # AGENTS.md is also checked since some projects use it instead.
  if ((!SKIP_CLAUDE_MD && !MODE_LOCAL_MD)); then
    for f in CLAUDE.md AGENTS.md; do
      target="$PROJECT_DIR/$f"
      if [[ -e "$target" && ! -L "$target" ]]; then
        die "$target already exists as a real file. Re-run with --no-claude-md to skip the CLAUDE.md symlink (the overlay's .claude/ dir will still be linked), or move/rename the project's file first."
      fi
    done
  fi

  if [[ -d "$OVERLAY" ]]; then
    info "Overlay already exists at $OVERLAY"
  else
    mkdir -p "$OVERLAY/.claude"
    # CLAUDE.md is intentionally empty — the project-claude-setup skill defers
    # CLAUDE.md content generation to `/init`, which reads the codebase. We
    # only create the file so the symlink target exists.
    : >"$OVERLAY/CLAUDE.md"
    cat >"$OVERLAY/.claude/settings.json" <<'EOF'
{
  "permissions": {
    "allow": []
  }
}
EOF
    ok "Scaffolded overlay at $OVERLAY"
  fi
fi

# ── link ─────────────────────────────────────────────────────────────────────
[[ -d "$OVERLAY" ]] || die "No overlay found at $OVERLAY. Run with --create to scaffold one."

link_one() {
  local src="$1" dst="$2"
  [[ -e "$src" ]] || {
    warn "skip: $src does not exist in overlay"
    return
  }
  if [[ -L "$dst" ]]; then
    local cur
    cur="$(readlink "$dst")"
    if [[ "$cur" == "$src" ]]; then
      ok "already linked: $dst"
      return
    fi
    warn "$dst already a symlink to $cur — leave it alone (remove manually if you want to relink)"
    return
  elif [[ -e "$dst" ]]; then
    case "$(basename "$dst")" in
      CLAUDE.md | AGENTS.md)
        die "$dst exists as a real file (project tracks it). Re-run with --local-md to write a CLAUDE.local.md import shim alongside it instead."
        ;;
      *)
        die "$dst exists as a real file/dir. Move or delete it first."
        ;;
    esac
  fi
  ln -s "$src" "$dst"
  ok "linked: $dst -> $src"
}

# Write a 1-line .local.md import shim that pulls in the overlay's master
# file via Claude Code's @~/ import syntax. Idempotent: if the file
# already exists with the correct import line, do nothing.
write_import_shim() {
  local overlay_path="$1" # e.g. ~/.dotfiles/projects/foo/CLAUDE.md
  local dst="$2"          # e.g. <project>/CLAUDE.local.md

  # Refuse to write a shim pointing at a source that doesn't exist (or
  # is a broken symlink). `-e` resolves through symlinks, so a dangling
  # link returns false — exactly the behavior we want.
  if [[ ! -e "$overlay_path" ]]; then
    warn "skip: overlay source $overlay_path does not exist; not writing $dst"
    return
  fi

  # Convert overlay_path to a @~/-prefixed form for portability across machines.
  local home_prefix="$HOME/"
  local import_target
  if [[ "$overlay_path" == "$home_prefix"* ]]; then
    import_target="@~/${overlay_path#$home_prefix}"
  else
    import_target="@${overlay_path}"
  fi
  local desired="${import_target}"

  if [[ -L "$dst" ]]; then
    warn "$dst is a symlink — leaving as-is. (Remove it manually if you want a .local.md import shim instead.)"
    return
  fi
  if [[ -e "$dst" ]]; then
    if grep -qxF "$desired" "$dst"; then
      ok "already has import: $dst"
      return
    fi
    warn "$dst exists and doesn't contain the expected import line. Leaving as-is. Add this manually if you want it:"
    warn "  $desired"
    return
  fi

  printf '%s\n' "$desired" >"$dst"
  ok "wrote import shim: $dst -> $desired"
}

# Merge personal allowlist entries from overlay's settings.local.json
# into the project's settings.local.json. jq dedupes the merged allow
# array while preserving insertion order. If the project file is
# tracked, the merge still happens but the function warns that the
# change will appear in 'git diff'.
merge_settings_local_json() {
  local src="$1" # overlay master
  local dst="$2" # project file (may not exist)

  if [[ ! -f "$src" ]]; then
    info "no overlay settings.local.json at $src, skipping"
    return
  fi

  if [[ ! -e "$dst" ]]; then
    # No project file — just copy. We don't symlink because the project
    # may want to maintain its own settings.local.json independently.
    cp "$src" "$dst"
    ok "wrote: $dst (copied from overlay)"
    return
  fi

  # Both exist. Detect tracked.
  local proj_root tracked=0
  proj_root="$(git -C "$(dirname "$dst")" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$proj_root" ]] && git -C "$proj_root" ls-files --error-unmatch -- "${dst#$proj_root/}" >/dev/null 2>&1; then
    tracked=1
  fi

  # Merge: deep-merge top-level, then dedupe permissions.allow.
  local merged
  merged=$(mktemp)
  jq -s '
    .[0] as $dst | .[1] as $src |
    (($dst // {}) * ($src // {})) |
    .permissions = ((.permissions // {}) | . + {
      allow: ((($dst.permissions.allow // []) + ($src.permissions.allow // []))
              | reduce .[] as $x ([]; if index($x) then . else . + [$x] end))
    })
  ' "$dst" "$src" >"$merged" || {
    rm -f "$merged"
    die "jq merge failed for $dst"
  }
  jq -e . "$merged" >/dev/null 2>&1 || {
    rm -f "$merged"
    die "jq produced invalid JSON merging $dst"
  }

  if diff -q "$dst" "$merged" >/dev/null; then
    ok "$dst already up to date"
    rm -f "$merged"
    return
  fi

  info "──── proposed diff (settings.local.json) ────"
  diff -u "$dst" "$merged" || true
  echo
  if ((tracked)); then
    warn "Note: $dst is tracked in git — this change will appear in 'git diff' in the project."
    warn "Decide whether to commit, stash, or revert after reviewing."
  fi
  read -r -p "Apply merge to $dst? [y/N] " a
  if [[ "${a:-N}" =~ ^[Yy]$ ]]; then
    cp "$dst" "${dst}.backup-$(date -u +%Y%m%dT%H%M%SZ)"
    cp "$merged" "$dst"
    ok "Updated: $dst"
  else
    warn "Skipped merge into $dst."
  fi
  rm -f "$merged"
}

# For each file under <overlay>/.claude/, create a per-file symlink at
# the analogous path inside <project>/.claude/, creating intermediate
# directories as needed. Skips files that already exist at the target
# unless they're symlinks pointing into our overlay (idempotent re-run).
#
# settings.local.json is special-cased: merged (via jq) instead of
# symlinked, because the project may have its own untracked
# settings.local.json the user wants preserved.
link_claude_dir_per_file() {
  local overlay_dir="$1" # ~/.dotfiles/projects/<slug>/.claude
  local project_dir="$2" # <project>/.claude

  [[ -d "$overlay_dir" ]] || {
    warn "no overlay .claude/ at $overlay_dir, nothing to link"
    return
  }
  command -v jq >/dev/null || die "jq required for --claude-dir-per-file (settings.local.json merge)"

  mkdir -p "$project_dir"

  local proj_root
  proj_root="$(git -C "$(dirname "$project_dir")" rev-parse --show-toplevel 2>/dev/null || true)"

  # Walk overlay's .claude tree, link each regular file individually.
  while IFS= read -r -d '' src <&3; do
    local rel="${src#$overlay_dir/}"
    local dst="$project_dir/$rel"

    # settings.local.json: merge, don't symlink.
    if [[ "$rel" == "settings.local.json" ]]; then
      merge_settings_local_json "$src" "$dst"
      continue
    fi

    mkdir -p "$(dirname "$dst")"

    if [[ -L "$dst" ]]; then
      local cur
      cur="$(readlink "$dst")"
      if [[ "$cur" == "$src" ]]; then
        ok "already linked: $dst"
        continue
      fi
      warn "$dst is a symlink to $cur — leaving as-is."
      continue
    fi
    if [[ -e "$dst" ]]; then
      # Real file at the target. If it's tracked in git, that's a
      # collision the user must resolve by renaming their overlay item.
      if [[ -n "$proj_root" ]] && git -C "$proj_root" ls-files --error-unmatch -- "${dst#$proj_root/}" >/dev/null 2>&1; then
        die "Collision: $dst is tracked in git. Rename your overlay item ($src) and re-run."
      fi
      warn "$dst exists (untracked, not a symlink). Skipping — move or remove it manually if you want to link the overlay version."
      continue
    fi
    ln -s "$src" "$dst"
    ok "linked: $dst -> $src"
  done 3< <(find "$overlay_dir" -type f -print0)
}

# CLAUDE.md handling: three paths.
#   --local-md   → write CLAUDE.local.md import shim (project tracks its own CLAUDE.md)
#   --no-claude-md → skip entirely (legacy; equivalent to "user doesn't want a personal CLAUDE.md")
#   default      → symlink overlay's CLAUDE.md into project (no tracked file in the way)
if ((MODE_LOCAL_MD)); then
  write_import_shim "$OVERLAY/CLAUDE.md" "$PROJECT_DIR/CLAUDE.local.md"
elif ((SKIP_CLAUDE_MD)); then
  info "Skipping CLAUDE.md symlink (--no-claude-md). Project keeps its own."
else
  link_one "$OVERLAY/CLAUDE.md" "$PROJECT_DIR/CLAUDE.md"
fi

# AGENTS.md handling: only when --local-md AND user opted into AGENTS too.
# Default off — most users don't keep an AGENTS overlay separately.
if ((MODE_LOCAL_MD && !SKIP_AGENTS_MD)); then
  if [[ -f "$OVERLAY/AGENTS.md" ]]; then
    write_import_shim "$OVERLAY/AGENTS.md" "$PROJECT_DIR/AGENTS.local.md"
  else
    info "Skipping AGENTS.local.md — no overlay AGENTS.md at $OVERLAY/AGENTS.md."
  fi
fi
if ((MODE_CLAUDE_PER_FILE)); then
  link_claude_dir_per_file "$OVERLAY/.claude" "$PROJECT_DIR/.claude"
else
  link_one "$OVERLAY/.claude" "$PROJECT_DIR/.claude"
fi

echo
info "Reminder: the global gitignore (~/.dotfiles/core/git/gitignore.symlink)"
info "ignores CLAUDE.md, CLAUDE.local.md, AGENTS.local.md and .claude/, so"
info "none of these will show up in git status inside the project."
